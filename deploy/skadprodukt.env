# Konfiguracja środowiska dla usług skadprodukt na serwerze (DESKTOP-JVH406L, WSL2).
# Kopiowana przez install-server.sh do /etc/skadprodukt.env i czytana przez jednostki systemd.
# Ścieżki install-server.sh podmienia automatycznie na realne; NTFY_TOPIC ustaw ręcznie.

# Repo serwisu (git clone — NIE folder OneDrive; unikamy wyścigów sync)
SKADPRODUKT_REPO=/home/serwer/skadprodukt
# Silnik renderu/uploadu (przeniesiony z laptopa; venv budowany lokalnie na serwerze)
SKADPRODUKT_ENGINE=/home/serwer/auto-content-engine
# Interpreter Pythona silnika (venv serwera)
SKADPRODUKT_PY=/home/serwer/auto-content-engine/.venv/bin/python
# Node do build.js / generate_shorts.js — ABSOLUTNA ścieżka (bash -lc nie zawsze ma PATH z nvm).
# install-server.sh wstawi tu wynik `command -v node`.
SKADPRODUKT_NODE=/usr/bin/node

# Strefa czasu procesów usług. UWAGA: timery systemd liczą OnCalendar w strefie SYSTEMOWEJ,
# więc dodatkowo ustaw ją na serwerze: sudo timedatectl set-timezone Europe/Warsaw
TZ=Europe/Warsaw

# Powiadomienia o awariach (darmowy ntfy.sh — ustaw własny, trudny do zgadnięcia temat).
# Subskrybuj ten temat w aplikacji ntfy na telefonie. UWAGA: temat jest publiczny —
# heartbeat wysyła tu tylko lakoniczne alerty, bez wrażliwych szczegółów.
NTFY_TOPIC=skadprodukt-serwer-alerts-ZMIEN-MNIE

# Scoring scouta: heuristic | ollama | claude.
# DOMYŚLNIE heuristic — bo scout chodzi CODZIENNIE; 'claude' = codzienne zużycie limitu Pro
# (włącz świadomie, dopiero gdy `claude -p` jest zalogowany na serwerze).
# 'ollama' = lokalny model na RTX 4060 Ti (0 zł) — najlepszy kompromis, gdy zainstalujesz Ollamę.
SCOUT_SCORER=heuristic
